generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
//  directUrl = env("DIRECT_URL")
}

// ─── Reference Number Counter ────────────────────────────────────────────────
model ApplicationCounter {
  missionCode LocalMissionCode
  year        Int
  lastSerial  Int              @default(0)

  @@id([missionCode, year])
  @@map("application_counters")
}

// ─── Local Missions ───────────────────────────────────────────────────────────
model LocalMission {
  id                 String              @id @default(cuid())
  code               LocalMissionCode    @unique
  name               String
  nameBangla         String
  description        String?
  contactEmail       String?
  contactPhone       String?
  address            String?
  directorId         String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  applicationWindows ApplicationWindow[]
  applications       Application[]       @relation("ApplicationSubmittedFromMission")
  complaints         Complaint[]
  director           User?               @relation("MissionDirector", fields: [directorId], references: [id])
  users              User[]              @relation("UserHomeMission")
  lmdReports         LmdReport[]         @relation("LmdReportMission")
  salaryRanges            SalaryRange[]
  salaryAssignments       SalaryAssignment[]
  salaryRequests          SalaryRequest[]

  @@index([code])
  @@map("local_missions")
}

model UserFlagRequest {
  id            String          @id @default(cuid())
  targetUserId  String
  requestedById String
  reason        String
  status        FlagRequestStatus @default(PENDING)
  resolvedById  String?
  resolvedAt    DateTime?
  resolverNote  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  targetUser    User            @relation("FlaggedUser", fields: [targetUserId], references: [id])
  requestedBy   User            @relation("FlagRequestedBy", fields: [requestedById], references: [id])
  resolvedBy    User?           @relation("FlagResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([targetUserId])
  @@map("user_flag_requests")
}

// ─── Salary ───────────────────────────────────────────────────────────────────
model SalaryRange {
  id          String       @id @default(cuid())
  missionId   String       @unique
  minAmount   Int
  maxAmount   Int
  cycle       Int
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mission     LocalMission @relation(fields: [missionId], references: [id])
  createdBy   User         @relation("SalaryRangeCreatedBy", fields: [createdById], references: [id])
}

model SalaryAssignment {
  id           String       @id @default(cuid())
  missionaryId String
  missionId    String
  amount       Int
  deploymentLocation String?
  cycle        Int
  assignedById String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  missionary   User         @relation("MissionarySalaryAssignments", fields: [missionaryId], references: [id])
  mission      LocalMission @relation(fields: [missionId], references: [id])
  assignedBy   User         @relation("SalaryAssignedBy", fields: [assignedById], references: [id])

  @@unique([missionaryId, cycle])
  @@map("salary_assignments")
}

model SalaryRequest {
  id           String              @id @default(cuid())
  missionaryId String
  missionId    String
  amount       Int
  month        Int
  year         Int
  status       SalaryRequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  missionary   User                @relation("MissionarySalaryRequests", fields: [missionaryId], references: [id])
  mission      LocalMission        @relation(fields: [missionId], references: [id])
  reviewedBy   User?               @relation("SalaryRequestReviewedBy", fields: [reviewedById], references: [id])

  @@unique([missionaryId, month, year])
  @@map("salary_requests")
}
// ─── Urgent Reports ────────────────────────────────────────────────────────────────────
model UrgentReport {
  id          String   @id @default(cuid())
  title       String
  body        String
  issuedById  String
  // Up to 5 attachment storage keys (local filesystem / R2)
  attachment1 String?
  attachment2 String?
  attachment3 String?
  attachment4 String?
  attachment5 String?
  // Original filenames for display
  attachment1Name String?
  attachment2Name String?
  attachment3Name String?
  attachment4Name String?
  attachment5Name String?

  publishedAt DateTime  @default(now())
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  issuedBy    User                    @relation("UrgentReportIssuedBy", fields: [issuedById], references: [id])
  submissions UrgentReportSubmission[]

  @@index([publishedAt])
  @@map("urgent_reports")
}

model UrgentReportSubmission {
  id       String @id @default(cuid())
  reportId String
  userId   String
  response String?   // optional text from missionary
  submittedAt DateTime @default(now())

  report UrgentReport @relation(fields: [reportId], references: [id])
  user   User         @relation("UrgentReportSubmissions", fields: [userId], references: [id])

  @@unique([reportId, userId])   // one submission per missionary per report
  @@index([reportId])
  @@index([userId])
  @@map("urgent_report_submissions")
}
// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  emailVerified           DateTime?
  passwordHash            String
  fullName                String
  fullNameBangla          String?
  phone                   String?
  dateOfBirth             DateTime?
  preferredLanguage       String                   @default("en")
  role                    UserRole                 @default(TRAINEE)
  homeMissionId           String
  isActive                Boolean                  @default(true)
  failedLoginCount        Int                      @default(0)
  isMissionary            Boolean                  @default(false)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  uploadedDocuments       ApplicationDocument[]    @relation("DocumentUploadedBy")
  windowsCreated          ApplicationWindow[]      @relation("WindowCreatedBy")
  applications            Application[]            @relation("ApplicationApplicant")
  reviewedAsDirector      Application[]            @relation("ApplicationDirectorReviewer")
  reviewedAsLmd           Application[]            @relation("ApplicationLmdReviewer")
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  directedMission         LocalMission?            @relation("MissionDirector")
  fieldReports            FieldReport[]
  notifications           Notification[]
  passwordResetTokens     PasswordResetToken[]
  complaints              Complaint[]              @relation("ComplaintSubmittedBy")
  resolvedComplaints      Complaint[]              @relation("ComplaintResolvedBy")
  announcements           Announcement[]           @relation("AnnouncementCreatedBy")
  enrollmentsAsTrainee    ProgramEnrollment[]
  recommendations         Recommendation[]
  sessionsHistory         Session[]
  homeMission             LocalMission             @relation("UserHomeMission", fields: [homeMissionId], references: [id])
  trainingsAsTrainer      TrainingProgram[]        @relation("ProgramTrainers")
  deploymentAssignments   ProgramEnrollment[]      @relation("DeploymentAssignedBy")
  fieldReportComments     FieldReportComment[]     @relation("FieldReportCommentAuthor")
  lmdReportWindowsCreated LmdReportWindow[]        @relation("LmdReportWindowCreatedBy")
  lmdReports              LmdReport[]              @relation("LmdReportAuthor")
  flagRequests            UserFlagRequest[]        @relation("FlaggedUser")
  flagRequestsMade        UserFlagRequest[]        @relation("FlagRequestedBy")
  flagRequestsResolved    UserFlagRequest[]        @relation("FlagResolvedBy")
  salaryRangesCreated     SalaryRange[]            @relation("SalaryRangeCreatedBy")
  salaryAssignments       SalaryAssignment[]       @relation("MissionarySalaryAssignments")
  salaryAssignmentsMade   SalaryAssignment[]       @relation("SalaryAssignedBy")
  salaryRequests          SalaryRequest[]          @relation("MissionarySalaryRequests")
  salaryRequestsReviewed  SalaryRequest[]          @relation("SalaryRequestReviewedBy")
  trainerApplicationsReviewed TrainerApplication[] @relation("TrainerApplicationReviewedBy")
  trainerApplicationCreated   TrainerApplication?  @relation("TrainerApplicationCreatedUser")
  urgentReportsIssued    UrgentReport[]           @relation("UrgentReportIssuedBy")
  urgentReportSubmissions UrgentReportSubmission[] @relation("UrgentReportSubmissions")

  @@index([email])
  @@index([homeMissionId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verification_tokens")
}

// ─── Trainer ────────────────────────────────────────────────────────────
model TrainerApplication {
  id              String                    @id @default(cuid())

  // Personal info
  fullName        String
  email           String
  phone           String?
  fullAddress     String
  specialization  String                    // free text — what they teach / area of expertise

  // Uploaded file storage keys (served via /api/uploads/[...path])
  cvStorageKey          String?             // kind: TRAINER_CV
  passportStorageKey    String?             // kind: TRAINER_PASSPORT
  photoStorageKey       String?             // kind: TRAINER_PHOTO (PP sized)

  // Checkbox acknowledgements
  acceptsSelfFunding    Boolean             @default(false)  // "responsible for own expenses"
  requestsInvitationLetter Boolean          @default(false)  // "needs invitation letter"

  // Workflow
  status          TrainerApplicationStatus  @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNote      String?                   // SA internal note (rejection reason or approval note)

  // If approved — link to the created User account
  createdUserId   String?                   @unique

  ipAddress       String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  reviewedBy      User?                     @relation("TrainerApplicationReviewedBy", fields: [reviewedById], references: [id])
  createdUser     User?                     @relation("TrainerApplicationCreatedUser", fields: [createdUserId], references: [id])

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("trainer_applications")
}

// ─── Announcements ────────────────────────────────────────────────────────────
model Announcement {
  id            String    @id @default(cuid())
  title         String
  body          String
  attachmentUrl String?
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdBy     User      @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])

  @@index([publishedAt])
  @@index([expiresAt])
  @@map("announcements")
}

// ─── Training Programs ────────────────────────────────────────────────────────
model TrainingProgram {
  id                 String              @id @default(cuid())
  code               String              @unique
  title              String
  titleBangla        String?
  category           TrainingCategory
  summary            String?
  summaryBangla      String?
  payloadContentId   String?
  startDate          DateTime
  endDate            DateTime
  location           String?
  locationBangla     String?
  targetIntake       Int
  maxIntake          Int?
  isPublished        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  applicationWindows ApplicationWindow[]
  enrollments        ProgramEnrollment[]
  fieldReports       FieldReport[]
  trainers           User[]              @relation("ProgramTrainers")
  isMain                  Boolean                  @default(false)

  @@index([category])
  @@index([startDate])
  @@index([code])
  @@map("training_programs")
}

model ProgramEnrollment {
  id                     String          @id @default(cuid())
  programId              String
  traineeId              String
  applicationId          String?         @unique
  enrolledAt             DateTime        @default(now())
  attendanceConfirmed    Boolean         @default(false)
  certificateIssued      Boolean         @default(false)
  certificateIssuedAt    DateTime?
  deploymentLocation     String?
  deploymentLatitude     Float?
  deploymentLongitude    Float?
  deploymentAssignedAt   DateTime?
  deploymentAssignedById String?
  notes                  String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?
  application            Application?    @relation(fields: [applicationId], references: [id])
  program                TrainingProgram @relation(fields: [programId], references: [id])
  trainee                User            @relation(fields: [traineeId], references: [id])
  deploymentAssignedBy   User?           @relation("DeploymentAssignedBy", fields: [deploymentAssignedById], references: [id])

  @@unique([programId, traineeId])
  @@index([programId])
  @@index([traineeId])
  @@index([deploymentLocation])
  @@map("program_enrollments")
}

model ApplicationWindow {
  id                   String                 @id @default(cuid())
  programId            String
  scopedToMissionId    String?
  state                ApplicationWindowState @default(DRAFT)
  advertisingStartDate DateTime
  applicationOpenDate  DateTime
  applicationCloseDate DateTime
  trainingStartDate    DateTime
  targetIntake         Int
  notes                String?
  createdById          String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  createdBy            User                   @relation("WindowCreatedBy", fields: [createdById], references: [id])
  program              TrainingProgram        @relation(fields: [programId], references: [id])
  scopedToMission      LocalMission?          @relation(fields: [scopedToMissionId], references: [id])
  applications         Application[]

  @@index([programId])
  @@index([state])
  @@index([scopedToMissionId])
  @@map("application_windows")
}

// ─── Application ──────────────────────────────────────────────────────────────
model Application {
  id              String  @id @default(cuid())
  referenceNumber String? @unique

  // ── Applicant link ──
  applicantId String
  applicant   User   @relation("ApplicationApplicant", fields: [applicantId], references: [id])

  // ── Window / Mission ──
  windowId               String
  window                 ApplicationWindow @relation(fields: [windowId], references: [id])
  submittedFromMissionId String
  submittedFromMission   LocalMission      @relation("ApplicationSubmittedFromMission", fields: [submittedFromMissionId], references: [id])

  // ── Status & workflow ──
  status           ApplicationStatus @default(DRAFT)
  submittedAt      DateTime?
  lastTransitionAt DateTime?

  // ── Promoted personal detail columns ──
  applicantFullName       String
  applicantFullNameBangla String?
  applicantDateOfBirth    DateTime
  applicantAge            Int
  applicantGender         Gender
  applicantBloodType      BloodType?
  applicantMaritalStatus  MaritalStatus?
  applicantDenomination   Denomination?
  applicantMobileNo       String?
  applicantEmail          String?
  applicantPlaceOfBirth   String?
  applicantHeight         Float?
  applicantWeight         Float?
  applicantChurchName     String?
  applicantDateOfBaptism  DateTime?
  applicantWorkplace      String?

  // ── Address columns ──
  presentAddressDistrict     String?
  presentAddressUpazila      String?
  presentAddressPostOffice   String?
  presentAddressVillage      String?
  permanentAddressDistrict   String?
  permanentAddressUpazila    String?
  permanentAddressPostOffice String?
  permanentAddressVillage    String?
  permanentSameAsPresent     Boolean @default(false)

  // ── Profile photo shortcut ──
  profilePhotoDocumentId String?

  // ── Family details ──
  fatherName       String?
  fatherAge        Int?
  fatherReligion   Religion?
  fatherChurchName String?
  motherName       String?
  motherAge        Int?
  motherReligion   Religion?
  motherChurchName String?
  familyMobileNo   String?
  familyEmail      String?

  // ── Form data ──
  formData    Json
  formVersion Int  @default(1)

  // ── LMD review ──
  lmdReviewerId        String?
  lmdReviewer          User?     @relation("ApplicationLmdReviewer", fields: [lmdReviewerId], references: [id])
  lmdReviewStartedAt   DateTime?
  lmdReviewCompletedAt DateTime?
  lmdReviewerComment   String?

  // ── LMD rejection (hidden from applicant) ──
  lmdRejectionReason String?

  // ── Director review ──
  directorReviewerId        String?
  directorReviewer          User?     @relation("ApplicationDirectorReviewer", fields: [directorReviewerId], references: [id])
  directorReviewStartedAt   DateTime?
  directorReviewCompletedAt DateTime?
  directorReviewerComment   String?

  // ── Rejection (visible to applicant — set by Director only) ──
  rejectionReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  documents      ApplicationDocument[]
  statusHistory  ApplicationStatusHistory[]
  enrollment     ProgramEnrollment?
  recommendation Recommendation?
  fieldReports   FieldReport[]

  @@unique([applicantId, windowId])
  @@index([applicantId])
  @@index([windowId])
  @@index([submittedFromMissionId])
  @@index([status])
  @@index([submittedAt])
  @@map("applications")
}

model ApplicationStatusHistory {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  triggeredById String
  comment       String?
  createdAt     DateTime           @default(now())
  application   Application        @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_status_history")
}

// ─── Recommendation ───────────────────────────────────────────────────────────
model Recommendation {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  recommenderId  String
  writtenComment String?
  recommendedAt  DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  application    Application @relation(fields: [applicationId], references: [id])
  recommender    User        @relation(fields: [recommenderId], references: [id])

  @@index([recommenderId])
  @@map("recommendations")
}

// ─── Application Documents ───────────────────────────────────────────────────
model ApplicationDocument {
  id                  String       @id @default(cuid())
  applicationId       String
  kind                DocumentKind
  fileName            String
  mimeType            String
  fileSizeBytes       Int
  storageKey          String
  checksum            String?
  formVersion         Int?
  educationEntryIndex Int?
  uploadedById        String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  application         Application  @relation(fields: [applicationId], references: [id])
  uploadedBy          User         @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([applicationId])
  @@index([kind])
  @@map("application_documents")
}

// ─── Field Reports ────────────────────────────────────────────────────────────
model FieldReport {
  id            String   @id @default(cuid())
  traineeId     String
  applicationId String
  programId     String
  reportMonth   Int      // 1–12
  reportYear    Int

  // Auto-filled at submit time
  workplaceSnapshot String?
  lmdNameSnapshot   String?

  // Activity metrics
  totalActivities           Int @default(0)
  daysOfWork                Int @default(0)
  hoursOfWork               Int @default(0)
  nonSdaHomeVisits          Int @default(0)
  bibleStudiesConducted     Int @default(0)
  medicalVisits             Int @default(0)
  worshipSessionsTaken      Int @default(0)
  newGroupsMade             Int @default(0)
  baptismCandidatesPrepared Int @default(0)
  numberOfBaptisms          Int @default(0)

  // Narrative fields
  activitiesSummary     String
  trainingReceived      String?
  storyOrWitness        String?
  commentsOrSuggestions String?
  challengesFaced       String?
  prayerRequests        String?
  peopleReached         Int?

  // Attachments
  attachments Json?

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainee     User               @relation(fields: [traineeId], references: [id])
  application Application        @relation(fields: [applicationId], references: [id])
  program     TrainingProgram    @relation(fields: [programId], references: [id])
  comments    FieldReportComment[]

  @@unique([traineeId, reportMonth, reportYear])
  @@index([traineeId])
  @@index([programId])
  @@index([reportYear, reportMonth])
  @@map("field_reports")
}

model FieldReportComment {
  id        String      @id @default(cuid())
  reportId  String
  authorId  String
  comment   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  report    FieldReport @relation(fields: [reportId], references: [id])
  author    User        @relation("FieldReportCommentAuthor", fields: [authorId], references: [id])

  @@index([reportId])
  @@map("field_report_comments")
}

// ─── Complaints ───────────────────────────────────────────────────────────────
model Complaint {
  id            String            @id @default(cuid())
  category      ComplaintCategory
  subject       String
  description   String
  isAnonymous   Boolean           @default(true)
  submittedById String?
  missionCode   LocalMissionCode?
  missionId     String?
  isResolved    Boolean           @default(false)
  resolvedAt    DateTime?
  resolvedById  String?
  response      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  submittedBy   User?             @relation("ComplaintSubmittedBy", fields: [submittedById], references: [id])
  resolvedBy    User?             @relation("ComplaintResolvedBy", fields: [resolvedById], references: [id])
  mission       LocalMission?     @relation(fields: [missionId], references: [id])

  @@index([missionCode])
  @@index([isResolved])
  @@index([category])
  @@index([createdAt])
  @@map("complaints")
}

// ─── Donations ────────────────────────────────────────────────────────────────
model Donation {
  id                     String         @id @default(cuid())
  donorName              String?
  donorEmail             String?
  donorPhone             String?
  donorMessage           String?
  isAnonymous            Boolean        @default(false)
  userId                 String?
  amountMinor            BigInt
  currency               String
  gateway                PaymentGateway
  status                 DonationStatus @default(PENDING)
  gatewayTransactionId   String?
  gatewayResponsePayload Json?
  initiatedAt            DateTime       @default(now())
  completedAt            DateTime?
  refundedAt             DateTime?
  receiptNumber          String?        @unique
  receiptSentAt          DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?

  @@index([gateway])
  @@index([status])
  @@index([completedAt])
  @@index([donorEmail])
  @@map("donations")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
model AuditLog {
  id               String            @id @default(cuid())
  action           AuditAction
  severity         AuditSeverity     @default(INFO)
  actorId          String?
  actorRole        UserRole?
  actorMissionCode LocalMissionCode?
  targetType       String?
  targetId         String?
  ipAddress        String?
  userAgent        String?
  details          Json?
  createdAt        DateTime          @default(now())
  actor            User?             @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id             String              @id @default(cuid())
  userId         String
  channel        NotificationChannel
  templateKey    String
  templateData   Json?
  emailMessageId String?
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  readAt         DateTime?
  actionUrl      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([channel])
  @@index([sentAt])
  @@index([readAt])
  @@map("notifications")
}

// ─── Contact / System ────────────────────────────────────────────────────────
model ContactMessage {
  id          String    @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  subject     String?
  message     String
  ipAddress   String?
  isSpam      Boolean   @default(false)
  isHandled   Boolean   @default(false)
  handledAt   DateTime?
  handledById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([isHandled])
  @@index([createdAt])
  @@map("contact_messages")
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("system_settings")
}

// ─── LMD Report Windows ───────────────────────────────────────────────────────
// Opened by UD/SA. When OPEN, LMDs can submit their monthly summary report.
model LmdReportWindow {
  id          String             @id @default(cuid())
  reportMonth Int                // 1–12
  reportYear  Int
  state       LmdReportWindowState @default(OPEN)
  notes       String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("LmdReportWindowCreatedBy", fields: [createdById], references: [id])
  reports     LmdReport[]

  @@unique([reportMonth, reportYear])
  @@index([state])
  @@map("lmd_report_windows")
}

// ─── LMD Reports ─────────────────────────────────────────────────────────────
// Monthly summary report submitted by an LMD covering all their trainees.
model LmdReport {
  id          String          @id @default(cuid())
  windowId    String
  lmdId       String
  missionId   String
  reportMonth Int
  reportYear  Int

  // ── Aggregated metrics (from trainee field reports) ──
  totalTrainees            Int @default(0)
  totalActivities          Int @default(0)
  totalDaysOfWork          Int @default(0)
  totalHoursOfWork         Int @default(0)
  totalNonSdaHomeVisits    Int @default(0)
  totalBibleStudies        Int @default(0)
  totalMedicalVisits       Int @default(0)
  totalWorshipSessions     Int @default(0)
  totalNewGroups           Int @default(0)
  totalBaptismCandidates   Int @default(0)
  totalBaptisms            Int @default(0)
  totalPeopleReached       Int @default(0)

  // ── LMD narrative ──
  overallSummary           String
  challengesAndNeeds       String?
  recommendationsToDirector String?
  prayerRequests           String?

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  window  LmdReportWindow @relation(fields: [windowId], references: [id])
  lmd     User            @relation("LmdReportAuthor", fields: [lmdId], references: [id])
  mission LocalMission    @relation("LmdReportMission", fields: [missionId], references: [id])

  @@unique([lmdId, reportMonth, reportYear])
  @@index([windowId])
  @@index([missionId])
  @@map("lmd_reports")
}

