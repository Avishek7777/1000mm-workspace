generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The four regional subdivisions of 1000MM. Fixed at seed time;
/// extending requires a code change + migration (intentional).
model LocalMission {
  id                 String              @id @default(cuid())
  code               LocalMissionCode    @unique
  name               String
  nameBangla         String
  description        String?
  contactEmail       String?
  contactPhone       String?
  address            String?
  directorId         String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  applicationWindows ApplicationWindow[]
  applications       Application[]       @relation("ApplicationSubmittedFromMission")
  director           User?               @relation("MissionDirector", fields: [directorId], references: [id])
  users              User[]              @relation("UserHomeMission")

  @@index([code])
  @@map("local_missions")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  emailVerified           DateTime?
  passwordHash            String
  fullName                String
  fullNameBangla          String?
  phone                   String?
  dateOfBirth             DateTime?
  preferredLanguage       String                   @default("en")
  role                    UserRole                 @default(TRAINEE)
  homeMissionId           String
  isActive                Boolean                  @default(true)
  failedLoginCount        Int                      @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  uploadedDocuments       ApplicationDocument[]    @relation("DocumentUploadedBy")
  windowsCreated          ApplicationWindow[]      @relation("WindowCreatedBy")
  applications            Application[]            @relation("ApplicationApplicant")
  reviewedAsDirector      Application[]            @relation("ApplicationDirectorReviewer")
  reviewedAsLmd           Application[]            @relation("ApplicationLmdReviewer")
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  directedMission         LocalMission?            @relation("MissionDirector")
  notifications           Notification[]
  passwordResetTokens     PasswordResetToken[]
  enrollmentsAsTrainee    ProgramEnrollment[]
  recommendations         Recommendation[]
  sessionsHistory         Session[]
  homeMission             LocalMission             @relation("UserHomeMission", fields: [homeMissionId], references: [id])
  trainingsAsTrainer      TrainingProgram[]        @relation("ProgramTrainers")

  @@index([email])
  @@index([homeMissionId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verification_tokens")
}

model TrainingProgram {
  id                 String              @id @default(cuid())
  code               String              @unique
  title              String
  titleBangla        String?
  category           TrainingCategory
  summary            String?
  summaryBangla      String?
  payloadContentId   String?
  startDate          DateTime
  endDate            DateTime
  location           String?
  locationBangla     String?
  targetIntake       Int
  maxIntake          Int?
  isPublished        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  applicationWindows ApplicationWindow[]
  enrollments        ProgramEnrollment[]
  trainers           User[]              @relation("ProgramTrainers")

  @@index([category])
  @@index([startDate])
  @@index([code])
  @@map("training_programs")
}

/// A confirmed trainee in a confirmed program. Created when an
/// Application reaches ACCEPTED and the trainee confirms attendance.
model ProgramEnrollment {
  id                  String          @id @default(cuid())
  programId           String
  traineeId           String
  applicationId       String?         @unique
  enrolledAt          DateTime        @default(now())
  attendanceConfirmed Boolean         @default(false)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  application         Application?    @relation(fields: [applicationId], references: [id])
  program             TrainingProgram @relation(fields: [programId], references: [id])
  trainee             User            @relation(fields: [traineeId], references: [id])

  @@unique([programId, traineeId])
  @@index([programId])
  @@index([traineeId])
  @@map("program_enrollments")
}

model ApplicationWindow {
  id                   String                 @id @default(cuid())
  programId            String
  scopedToMissionId    String?
  state                ApplicationWindowState @default(DRAFT)
  advertisingStartDate DateTime
  applicationOpenDate  DateTime
  applicationCloseDate DateTime
  trainingStartDate    DateTime
  targetIntake         Int
  notes                String?
  createdById          String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  createdBy            User                   @relation("WindowCreatedBy", fields: [createdById], references: [id])
  program              TrainingProgram        @relation(fields: [programId], references: [id])
  scopedToMission      LocalMission?          @relation(fields: [scopedToMissionId], references: [id])
  applications         Application[]

  @@index([programId])
  @@index([state])
  @@index([scopedToMissionId])
  @@map("application_windows")
}

model Application {
  id                        String                     @id @default(cuid())
  referenceNumber           String?                    @unique
  applicantId               String
  windowId                  String
  submittedFromMissionId    String
  status                    ApplicationStatus          @default(DRAFT)
  submittedAt               DateTime?
  lastTransitionAt          DateTime?
  applicantFullName         String
  applicantFullNameBangla   String?
  applicantDateOfBirth      DateTime
  applicantGender           String
  applicantMaritalStatus    String?
  educationLevel            String?
  permanentAddressCity      String?
  permanentAddressDivision  String?
  currentAddressCity        String?
  currentAddressDivision    String?
  nidOrPassport             String?
  formData                  Json
  formVersion               Int                        @default(1)
  lmdReviewerId             String?
  lmdReviewStartedAt        DateTime?
  lmdReviewCompletedAt      DateTime?
  directorReviewerId        String?
  directorReviewStartedAt   DateTime?
  directorReviewCompletedAt DateTime?
  lmdReviewerComment        String?
  directorReviewerComment   String?
  rejectionReason           String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  deletedAt                 DateTime?
  documents                 ApplicationDocument[]
  statusHistory             ApplicationStatusHistory[]
  applicant                 User                       @relation("ApplicationApplicant", fields: [applicantId], references: [id])
  directorReviewer          User?                      @relation("ApplicationDirectorReviewer", fields: [directorReviewerId], references: [id])
  lmdReviewer               User?                      @relation("ApplicationLmdReviewer", fields: [lmdReviewerId], references: [id])
  submittedFromMission      LocalMission               @relation("ApplicationSubmittedFromMission", fields: [submittedFromMissionId], references: [id])
  window                    ApplicationWindow          @relation(fields: [windowId], references: [id])
  enrollment                ProgramEnrollment?
  recommendation            Recommendation?

  @@unique([applicantId, windowId])
  @@index([applicantId])
  @@index([windowId])
  @@index([submittedFromMissionId])
  @@index([status])
  @@index([submittedAt])
  @@map("applications")
}

/// Append-only history of every status transition for an application.
/// One row per transition. The current status on Application is the
/// "head" of this list, but the list itself is the source of truth
/// for "show me the timeline of this application."
model ApplicationStatusHistory {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  triggeredById String
  comment       String?
  createdAt     DateTime           @default(now())
  application   Application        @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_status_history")
}

/// One recommendation per application (from the LMD). Files attached
/// are stored as ApplicationDocument with kind=RECOMMENDATION_LETTER.
model Recommendation {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  recommenderId  String
  writtenComment String?
  recommendedAt  DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  application    Application @relation(fields: [applicationId], references: [id])
  recommender    User        @relation(fields: [recommenderId], references: [id])

  @@index([recommenderId])
  @@map("recommendations")
}

/// Any file attached to an application — generated PDF, recommendation
/// scan, profile photo, supporting docs. Files live in object storage
/// (Cloudflare R2); this row stores metadata + storage key.
model ApplicationDocument {
  id            String       @id @default(cuid())
  applicationId String
  kind          DocumentKind
  fileName      String
  mimeType      String
  fileSizeBytes Int
  storageKey    String
  checksum      String?
  formVersion   Int?
  uploadedById  String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  application   Application  @relation(fields: [applicationId], references: [id])
  uploadedBy    User         @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([applicationId])
  @@index([kind])
  @@map("application_documents")
}

model Donation {
  id                     String         @id @default(cuid())
  donorName              String?
  donorEmail             String?
  donorPhone             String?
  donorMessage           String?
  isAnonymous            Boolean        @default(false)
  userId                 String?
  amountMinor            BigInt
  currency               String
  gateway                PaymentGateway
  status                 DonationStatus @default(PENDING)
  gatewayTransactionId   String?
  gatewayResponsePayload Json?
  initiatedAt            DateTime       @default(now())
  completedAt            DateTime?
  refundedAt             DateTime?
  receiptNumber          String?        @unique
  receiptSentAt          DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?

  @@index([gateway])
  @@index([status])
  @@index([completedAt])
  @@index([donorEmail])
  @@map("donations")
}

/// Append-only audit log. Database-level write-once enforcement is
/// done by a Postgres trigger (see migrations) that prevents UPDATE
/// and DELETE on this table for non-superuser roles.
model AuditLog {
  id               String            @id @default(cuid())
  action           AuditAction
  severity         AuditSeverity     @default(INFO)
  actorId          String?
  actorRole        UserRole?
  actorMissionCode LocalMissionCode?
  targetType       String?
  targetId         String?
  ipAddress        String?
  userAgent        String?
  details          Json?
  createdAt        DateTime          @default(now())
  actor            User?             @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id             String              @id @default(cuid())
  userId         String
  channel        NotificationChannel
  templateKey    String
  templateData   Json?
  emailMessageId String?
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  readAt         DateTime?
  actionUrl      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([channel])
  @@index([sentAt])
  @@index([readAt])
  @@map("notifications")
}

model ContactMessage {
  id          String    @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  subject     String?
  message     String
  ipAddress   String?
  isSpam      Boolean   @default(false)
  isHandled   Boolean   @default(false)
  handledAt   DateTime?
  handledById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([isHandled])
  @@index([createdAt])
  @@map("contact_messages")
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("system_settings")
}

enum LocalMissionCode {
  EBM
  NBM
  SBM
  WBM
}

enum UserRole {
  TRAINEE
  TRAINER
  LOCAL_DIRECTOR
  MAIN_DIRECTOR
  SYSTEM_ADMIN
}

enum TrainingCategory {
  SPIRITUAL
  PHYSICAL
  MENTAL
  SOCIAL
}

enum ApplicationWindowState {
  DRAFT
  ADVERTISING
  OPEN
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_LMD_REVIEW
  RETURNED_TO_APPLICANT
  RECOMMENDED
  UNDER_MAIN_DIRECTOR_REVIEW
  RETURNED_TO_LMD
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  SSLCOMMERZ
  BKASH
}

enum AuditAction {
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILED
  AUTH_LOGOUT
  AUTH_PASSWORD_RESET_REQUESTED
  AUTH_PASSWORD_CHANGED
  USER_CREATED
  USER_ROLE_CHANGED
  USER_MISSION_CHANGED
  USER_DEACTIVATED
  USER_REACTIVATED
  APPLICATION_SUBMITTED
  APPLICATION_REVIEW_STARTED
  APPLICATION_RETURNED_TO_APPLICANT
  APPLICATION_RECOMMENDED
  APPLICATION_RETURNED_TO_LMD
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  APPLICATION_WITHDRAWN
  DOCUMENT_DOWNLOADED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  WINDOW_CREATED
  WINDOW_OPENED
  WINDOW_CLOSED
  WINDOW_EDITED
  DONATION_INITIATED
  DONATION_COMPLETED
  DONATION_REFUNDED
}

enum AuditSeverity {
  INFO
  NOTICE
  WARNING
  CRITICAL
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum DocumentKind {
  BIO_DATA_PDF
  RECOMMENDATION_LETTER
  SUPPORTING_DOCUMENT
  PROFILE_PHOTO
}
